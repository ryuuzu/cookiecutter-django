set shell := ["bash", "-uc"]

image_name := "{{ cookiecutter.project_slug }}_local_django"

compose_local := "docker compose -f docker-compose.local.yml"
compose_build := "docker compose -f docker-compose.local.build.yml"

# Default recipe -> list available commands
default:
    @just --list

# -------------------------
# Smart runner (private helper)
# exec into running container if present, else run --rm
# -------------------------
_run_smart CMD:
    #!/usr/bin/env bash
    set -euo pipefail
    RUNNING_DJANGO=$({{compose_local}} ps -q django)
    if [ -n "$RUNNING_DJANGO" ]; then
        echo "Using running django container"
        docker exec -it "$RUNNING_DJANGO" {{CMD}}
    else
        echo "No running container found. Using run --rm"
        {{compose_local}} run --rm django {{CMD}}
    fi

# -------------------------
# Dev helpers
# -------------------------

lint:
    just _run_smart "ruff check --fix"

format:
    just _run_smart "ruff format"

pytest:
    just _run_smart "pytest tests/"

pytest-coverage:
    just _run_smart "pytest --cov=core_apps --cov-report=html tests/"

bash:
    just _run_smart "bash"

shell:
    just _run_smart "python manage.py shell"

migrations:
    just _run_smart "python manage.py makemigrations"

migrate:
    just _run_smart "python manage.py migrate"

cs:
    just _run_smart "python manage.py collectstatic --noinput --clear"

createsuperuser:
    just _run_smart "python manage.py createsuperuser"

# usage: just add requests
add *ARGS:
    just _run_smart "uv add {{ARGS}}"

# -------------------------
# Dev server
# -------------------------

dev-server:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -z "$(docker images -q {{image_name}})" ]; then
        echo "Image missing. Building..."
        {{compose_build}} build
    fi
    {{compose_local}} up -d --remove-orphans
    {{compose_local}} logs django --follow

dev-server-build:
    {{compose_build}} build
    {{compose_local}} up -d --remove-orphans
    {{compose_local}} logs django --follow

dev-server-build-only:
    {{compose_build}} build

remove-dev-server:
    {{compose_local}} down

docker-up:
    {{compose_local}} up django

logs:
    {{compose_local}} logs django --follow

# -------------------------
# Management
# -------------------------

# usage: just manage createsuperuser
manage *ARGS:
    just _run_smart "python manage.py {{ARGS}}"

# -------------------------
# Dangerous stuff ☠️
# -------------------------

wipe-out:
    #!/usr/bin/env bash
    read -p "Type 'yes' to confirm: " ans
    if [ "$ans" = "yes" ]; then
        {{compose_local}} down -v --remove-orphans
    else
        echo "Aborted."
    fi
